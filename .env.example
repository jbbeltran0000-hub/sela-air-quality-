# SELA Air Quality System Configuration
# Copy this to .env and fill in your credentials
# DO NOT commit .env to GitHub - it contains secrets

# ============================================
# IMAP Configuration (Email-based form submission)
# ============================================
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_EMAIL=sela-reports@gmail.com
IMAP_PASSWORD=your-app-specific-password-here
IMAP_MAILBOX=SELA_Reports

# ============================================
# PurpleAir API
# ============================================
# Get free API key: https://develop.purpleair.com/
PURPLEAIR_API_KEY=your-purpleair-api-key
PURPLEAIR_MAX_DISTANCE_KM=2.0

# ============================================
# SCAQMD API (South Coast Air Quality Management District)
# ============================================
# Public data portal: https://www.aqmd.gov/
SCAQMD_API_KEY=your-scaqmd-api-key

# ============================================
# Google Sheets API (Ledger)
# ============================================
# Create Google Service Account: https://console.cloud.google.com/
GOOGLE_SHEETS_LEDGER_ID=your-google-sheet-id
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_CREDENTIALS_JSON=path/to/service-account-key.json

# ============================================
# Verification Logic Parameters
# ============================================
VERIFICATION_SPIKE_THRESHOLD=2.0  # > 2.0x standard deviation = verified
VERIFICATION_TIME_WINDOW_MINUTES=15  # Check sensor data ±15 min from report

# ============================================
# Data Storage & Logging
# ============================================
DATA_DIR=./data
LOGS_DIR=./logs

# ============================================
# System Configuration
# ============================================
IMAP_POLL_INTERVAL_SECONDS=30
DEBUG_MODE=False
